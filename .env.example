# Core service settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# OpenAI
OPENAI_API_KEY=
OPENAI_TRIAGE_MODEL=
OPENAI_REASONING_MODEL=
OPENAI_EMBEDDING_MODEL=

# Redis
REDIS_URL=redis://localhost:6379/0
ALERT_QUEUE_NAME=glassbox_sre:alerts

# Postgres / pgvector
DATABASE_URL=postgresql+psycopg://glassbox_sre:glassbox_sre@localhost:5432/glassbox_sre

# Prometheus / Alertmanager / OpenTelemetry demo
PROMETHEUS_URL=http://localhost:9090
ALERTMANAGER_URL=http://localhost:9093
OTEL_DEMO_BASE_URL=http://localhost:8080
FLAGD_URL=http://localhost:8013

# Local notifier
LOCAL_NOTIFIER_OUTPUT_PATH=logs/incident-briefs.jsonl

# Slack, unused until the Slack integration phase
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
SLACK_DEFAULT_CHANNEL_ID=

# LangSmith tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=glassbox-sre
